{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=ledgerpulse;Username=postgres;Password=postgres"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:8082"
    ]
  },
  "ApiSecurity": {
    "ApiKey": "ledgerpulse-dev-key"
  },
  "RateLimiting": {
    "LedgerWrite": {
      "PermitLimit": 55,
      "WindowSeconds": 1,
      "QueueLimit": 5
    },
    "ConsolidationProcess": {
      "PermitLimit": 5,
      "WindowSeconds": 1,
      "QueueLimit": 2
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
