@page "/ledger-entries"
@inject LedgerPulseApiClient ApiClient

<PageTitle>Ledger Entries</PageTitle>

<h1>Ledger Entries</h1>

<EditForm Model="_form" OnValidSubmit="SubmitAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Description</label>
        <InputText class="form-control" @bind-Value="_form.Description" />
    </div>

    <div class="mb-3">
        <label class="form-label">Amount</label>
        <InputNumber class="form-control" @bind-Value="_form.Amount" />
    </div>

    <div class="mb-3">
        <label class="form-label">Currency</label>
        <InputText class="form-control" @bind-Value="_form.Currency" />
    </div>

    <div class="mb-3">
        <label class="form-label">Business Date</label>
        <InputDate class="form-control" @bind-Value="_form.BusinessDate" />
    </div>

    <button class="btn btn-primary" type="submit">Register Entry</button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <p class="mt-3">@_message</p>
}

<button class="btn btn-secondary mt-3 mb-3" @onclick="LoadEntriesAsync">Refresh</button>

@if (_entries.Count == 0)
{
    <p>No entries were found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Business Date</th>
                <th>Description</th>
                <th>Amount</th>
                <th>Currency</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in _entries)
            {
                <tr>
                    <td>@entry.BusinessDate</td>
                    <td>@entry.Description</td>
                    <td>@entry.Amount</td>
                    <td>@entry.Currency</td>
                    <td>@entry.CreatedAtUtc.ToLocalTime()</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private RegisterLedgerEntryFormModel _form = new();
    private List<LedgerEntryViewModel> _entries = [];
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        await LoadEntriesAsync();
    }

    private async Task SubmitAsync()
    {
        await ApiClient.CreateLedgerEntryAsync(new RegisterLedgerEntryRequestModel(_form.Description, _form.Amount, _form.Currency, _form.BusinessDate));
        _message = "Ledger entry registered successfully.";
        _form = new RegisterLedgerEntryFormModel();
        await LoadEntriesAsync();
    }

    private async Task LoadEntriesAsync()
    {
        _entries = (await ApiClient.GetLedgerEntriesAsync()).ToList();
    }
}
