@page "/daily-consolidation"
@inject LedgerPulseApiClient ApiClient

<PageTitle>Daily Consolidation</PageTitle>

<h1>Daily Consolidation</h1>

<button class="btn btn-primary me-2" @onclick="ProcessAsync">Process Pending Outbox Messages</button>
<button class="btn btn-secondary" @onclick="LoadSummariesAsync">Refresh Summaries</button>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <p class="mt-3">@_message</p>
}

@if (_summaries.Count == 0)
{
    <p class="mt-3">No consolidated data available yet.</p>
}
else
{
    <table class="table mt-3">
        <thead>
            <tr>
                <th>Business Date</th>
                <th>Total Amount</th>
                <th>Entry Count</th>
                <th>Updated At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var summary in _summaries)
            {
                <tr>
                    <td>@summary.BusinessDate</td>
                    <td>@summary.TotalAmount</td>
                    <td>@summary.EntryCount</td>
                    <td>@summary.UpdatedAtUtc.ToLocalTime()</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<DailyLedgerSummaryViewModel> _summaries = [];
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        await LoadSummariesAsync();
    }

    private async Task ProcessAsync()
    {
        var result = await ApiClient.ProcessOutboxAsync();
        _message = $"Processed {result.ProcessedMessages} messages and ignored {result.IgnoredMessages}.";
        await LoadSummariesAsync();
    }

    private async Task LoadSummariesAsync()
    {
        _summaries = (await ApiClient.GetDailySummariesAsync()).ToList();
    }
}
